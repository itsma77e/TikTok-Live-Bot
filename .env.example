# Copia questo file in `.env` e compila i valori.
# Tutto il resto (modello AI, voce, system prompt, ringraziamenti) si gestisce
# dalla dashboard web, scheda "Impostazioni" — non serve toccare questo file.

# Username TikTok (senza @) della live a cui collegarsi. Puoi anche inserirlo
# dalla dashboard al momento della connessione.
TIKTOK_USERNAME=

# OpenAI API key. Necessaria per il modello cloud (GPT-4o mini) e per la
# memoria a lungo termine (gli embedding passano sempre da OpenAI).
# Puoi anche incollarla direttamente dalla dashboard.
OPENAI_API_KEY=

# Tavily API key — opzionale. Abilita il tool di ricerca web. Chiave gratuita
# su https://app.tavily.com. Anche questa si può inserire dalla dashboard.
TAVILY_API_KEY=
